        "Customer calls 703-646-7799",
        "Joe (ElevenLabs agent_5901km4ph423ekes6pq4jk8qhefk) takes order",
        "resolve_and_add API builds cart in DB (phone_carts table)",
        "checkout_link creates Square payment link",
        "checkout_sms texts link to caller via Twilio",
        "Customer pays via Square link",
        "Square webhook POST /api/webhooks/square",
        "Webhook creates transaction (source=phone_joe, status=fired)",
        "iPad PWA detects new remote order on next 10s poll",
        "iPad auto-fires to kitchen via /api/pwa/orders/fire-kitchen",
        "fire-kitchen routes to LAN printers via Pi box URL"
