  "techDebt": [
    {
      "id": "td-1",
      "title": "localStorage as optimistic cache",
      "impact": "high",
      "category": "data",
      "description": "Data drift between local storage and DB. Manager state, POS settings stored client-side.",
      "fix": "Migrate to server state with React Query or SWR. Remove localStorage reads as source of truth."
    },
    {
      "id": "td-2",
      "title": "BroadcastChannel for KDS sync",
      "impact": "high",
      "category": "architecture",
      "description": "KDS only syncs across same-browser tabs. Won't work across devices (iPad \u2194 kitchen display).",
      "fix": "Replace with WebSocket or Server-Sent Events for real-time cross-device sync."
    },
    {
      "id": "td-3",
      "title": "Manager store resets on refresh",
      "impact": "medium",
      "category": "data",
      "description": "Pending manager approvals (voids, comps, discounts) lost on page refresh.",
      "fix": "Persist pending approvals to DB or sessionStorage with recovery on mount."
    },
    {
      "id": "td-4",
      "title": "Channel pricing not in DB",
      "impact": "high",
      "category": "feature-gap",
      "description": "Same price on DoorDash, UberEats, and direct ordering. Should support per-channel markup (25% DD standard).",
      "fix": "Add channel_menu_overrides table + API. UI in integrations settings."
    },
    {
      "id": "td-5",
      "title": "Daypart scheduling not in DB",
      "impact": "medium",
      "category": "feature-gap",
      "description": "Full menu shown all day. No lunch/dinner/brunch daypart filtering.",
      "fix": "Add availableFrom/To, availableDays to MenuItem. Filter in POS, online ordering, phone AI."
    },
    {
      "id": "td-6",
      "title": "Square Terminal device ID in localStorage",
      "impact": "medium",
      "category": "data",
      "description": "Terminal pairing stored client-side. Lost on browser clear.",
      "fix": "Store device_id in RestaurantSetting or dedicated table."
    },
    {
      "id": "td-7",
      "title": "Printer configs in memory only",
      "impact": "medium",
      "category": "data",
      "description": "Printer station assignments cached in-memory. Server restart = reconfigure.",
      "fix": "Already have PrinterStation table \u2014 ensure all config reads from DB, not runtime cache."
    },
    {
      "id": "td-8",
      "title": "No OAuth flows for delivery platforms",
      "impact": "high",
      "category": "integration",
      "description": "DoorDash/UberEats/Grubhub integration pages exist but no actual OAuth connection routes.",
      "fix": "Implement OAuth2 flows for each platform once API access is granted."
    },
    {
      "id": "td-9",
      "title": "No inbound order sync from delivery platforms",
      "impact": "high",
      "category": "integration",
      "description": "Orders from DD/UE/GH don't flow into AI-R. Manual entry only.",
      "fix": "Webhook listeners + order normalization layer \u2192 DineInOrder with channel='doordash' etc."
    },
    {
      "id": "td-10",
      "title": "No guest profiles / customer database",
      "impact": "high",
      "category": "feature-gap",
      "description": "No way to track who ordered, visit history, favorites, dietary preferences. Critical for DD\u2192direct conversion strategy.",
      "fix": "guest_profiles table + link to orders. Build from receipt signups + phone orders."
    },
    {
      "id": "td-11",
      "title": "No inventory auto-deduction on order close",
      "impact": "medium",
      "category": "feature-gap",
      "description": "Inventory doesn't decrease when orders are completed. Requires manual stock counts.",
      "fix": "Order close hook \u2192 recipe lookup \u2192 deduct ingredient quantities. Add inventory_movements audit trail."
    },
    {
      "id": "td-12",
      "title": "Clerk middleware missing on /home/* routes",
      "impact": "high",
      "category": "security",
      "description": "Owner dashboard routes may be accessible without auth in some configurations.",
      "fix": "Add Clerk middleware.ts matcher for all /home/*, /settings/*, /api/pwa/* routes."
    }
  ],
  "phoneOrdering": {
    "description": "AI phone ordering via ElevenLabs Joe agent",
    "lastUpdated": "2026-03-20",
    "primaryPrintPath": {
      "description": "iPad (PWA) polls active orders every 10s. Remote orders (phone_joe, online, etc.) auto-fire to kitchen via fire-kitchen API from iPad on LAN.",
