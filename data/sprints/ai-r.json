  "lastCommit": {
    "hash": "a48fac4",
    "message": "feat(device-settings): add full Square-parity receipt & tipping options\n\nNew DeviceSettings data layer with tip collection mode, tip percentages,\nsmart tips, signature collection, kitchen ticket config, and printer\nrouting. Settings page at /home/settings/device with three sections\n(Receipt & Payment, Kitchen Ticket, Printer Routing). Receipt template\nupdated to respect auth slip settings (tip line, signature, item details,\ncustomer copy). Missing fields auto-backfilled from defaults.\n\nCo-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>",
    "branch": "feature/device-settings-square-parity",
    "date": "2026-03-14"
  },
  "recentCommits": [
    {
      "hash": "a48fac4",
      "message": "feat(device-settings): add full Square-parity receipt & tipping options\n\nNew DeviceSettings data layer with tip collection mode, tip percentages,\nsmart tips, signature collection, kitchen ticket config, and printer\nrouting. Settings page at /home/settings/device with three sections\n(Receipt & Payment, Kitchen Ticket, Printer Routing). Receipt template\nupdated to respect auth slip settings (tip line, signature, item details,\ncustomer copy). Missing fields auto-backfilled from defaults.\n\nCo-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>",
